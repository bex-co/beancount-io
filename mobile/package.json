{
  "name": "mobile-beancount",
  "private": true,
  "main": "expo-router/entry",
  "scheme": "beancount",
  "scripts": {
    "start": "expo start --tunnel",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "android:build": "expo run:android",
    "ios:build": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "test": "npm run lint && npm run typecheck && npm run test:unit",
    "test:unit": "node ./scripts/jest-lite-runner.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit && eslint src --quiet --cache --fix --ext .js,.tsx,.ts ",
    "format": "prettier . --cache --write",
    "format:check": "prettier . --cache --check",
    "codegen": "graphql-codegen",
    "bump": "npx tsx ./src/scripts/bump-version.ts",
    "bump-dummy": "npx tsx ./src/scripts/bump-version-dummy.ts",
    "deploy": "bash ./deploy.sh"
  },
  "dependencies": {
    "@apollo/client": "3.14.1",
    "@callstack/react-theme-provider": "^3.0.9",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5",
    "@hookform/resolvers": "^5.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@sentry/react-native": "~7.11.0",
    "buffer": "^6.0.3",
    "codemirror": "^6.0.2",
    "currency-icons": "^1.0.14",
    "d3": "^7.9.0",
    "expo": "~57.0.4",
    "expo-analytics": "^1.0.13",
    "expo-application": "~57.0.0",
    "expo-asset": "~57.0.3",
    "expo-build-properties": "~57.0.3",
    "expo-clipboard": "~57.0.0",
    "expo-constants": "~57.0.3",
    "expo-device": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image-picker": "^57.0.2",
    "expo-linking": "~57.0.2",
    "expo-localization": "~57.0.0",
    "expo-mixpanel-analytics": "0.0.7",
    "expo-router": "~57.0.4",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-store-review": "~57.0.0",
    "expo-updates": "~57.0.6",
    "expo-web-browser": "~57.0.0",
    "graphql": "^16.14.2",
    "i18n-js": "^4.5.1",
    "jwt-decode": "^4.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-error-boundary": "^6.0.0",
    "react-hook-form": "^7.69.0",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-modal-datetime-picker": "^18.0.0",
    "react-native-pager-view": "8.0.2",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.10.0",
    "zod": "^4.4.3"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native-safe-area-context",
        "react-native-pager-view",
        "react-native-reanimated",
        "react-native-svg",
        "react-native-worklets"
      ]
    }
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "resolutions": {
    "@types/node": "^26.1.0",
    "expo-constants": "~57.0.3"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.2.0",
    "@graphql-codegen/introspection": "^6.1.0",
    "@graphql-codegen/schema-ast": "^6.1.0",
    "@graphql-codegen/typescript": "^6.1.0",
    "@graphql-codegen/typescript-operations": "^6.1.0",
    "@graphql-codegen/typescript-react-apollo": "^4.4.2",
    "@types/d3": "^7.4.3",
    "@types/react": "~19.2.7",
    "ajv": "^8.17.1",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~57.0.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "expo-mcp": "~0.2.1",
    "prettier": "^3.7.4",
    "typescript": "~6.0.3"
  },
  "packageManager": "yarn@1.22.22",
  "version": "1.20260711.38"
}
